# Go build outputs
*.exe
*.exe~
*.dll
*.so
*.dylib
*.a
*.o
*.out
*.test

# Coverage and profiling
coverage.out
coverage.html
*.coverprofile
*.pprof
cpu.prof
mem.prof

# Build directories
bin/
build/

# dist: ignore binaries and runtime-generated files, but track apps/ plugins/ logs/
dist/*.exe
dist/*.exe~
dist/null-space_ed25519
dist/null-space_ed25519.pub
dist/logs/*
!dist/logs/.gitkeep

# Legacy root-level logs (pre-dist layout)
logs/*
!logs/.gitkeep

# Wish-generated SSH host keys
null-space_ed25519
null-space_ed25519.pub

# Go workspace files
go.work
go.work.sum

# Editor and OS files
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
